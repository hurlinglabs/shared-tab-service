{
  "name": "shared-tab-service-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "checks": "run-p format:check lint \"checks:pgks --force\"",
    "checks:pgks": "turbo run typecheck test",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@10.24.0"
}
